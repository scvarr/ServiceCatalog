DJANGO_SECRET_KEY=change-me-before-production
DJANGO_DEBUG=true
# Comma-separated hostnames used to access the application, without ports.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated full origins allowed to submit POST forms through a reverse proxy.
DJANGO_CSRF_TRUSTED_ORIGINS=
HOST_PORT=8380
POSTGRES_DB=servicecatalog
POSTGRES_USER=servicecatalog
POSTGRES_PASSWORD=change-me
# Static container IPs: change both values if the Docker subnet changes.
DB_CONTAINER_IP=172.30.0.11
WEB_CONTAINER_IP=172.30.0.10
POSTGRES_HOST=172.30.0.11
POSTGRES_PORT=5432
GLPI_ENABLED=false
GLPI_BASE_URL=https://glpi.example.internal
GLPI_API_VERSION=v2.3
GLPI_CLIENT_ID=
GLPI_CLIENT_SECRET=
GLPI_USERNAME=
GLPI_PASSWORD=
# Needed only when API documentation requires a GLPI web session. Usually ldap-1.
# Leave blank to use the source preselected on the GLPI login page.
GLPI_WEB_AUTH_SOURCE=
# Leave empty to use the system CA store; otherwise provide a CA file path inside the container.
GLPI_CA_BUNDLE=
GLPI_TIMEOUT_SECONDS=15
# Keep true by default. Set false only for an explicitly accepted internal GLPI deployment.
GLPI_TLS_VERIFY=true
# Optional read-only MySQL fallback. Used for processor data only when the
# documented GLPI API returns HTTP 200 with an empty component list.
GLPI_DB_ENABLED=false
GLPI_DB_HOST=
GLPI_DB_PORT=3306
GLPI_DB_NAME=glpi
GLPI_DB_USER=
GLPI_DB_PASSWORD=
GLPI_DB_TIMEOUT_SECONDS=10
GLPI_API_PAGE_SIZE=100
GLPI_COMPONENT_WORKERS=6
GLPI_DB_BATCH_SIZE=200
